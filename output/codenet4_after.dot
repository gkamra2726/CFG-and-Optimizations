digraph G {
  "Start" [style=filled fillcolor=lightblue];
  "decl i (1)" [style=filled fillcolor=lightblue];
  "decl sum = 0 (2)" [style=filled fillcolor=lightblue];
  "assign i = 0 (3)" [style=filled fillcolor=lightblue];
  "for i < 5 (4)" [style=filled fillcolor=lightblue];
  "loop (5)" [style=filled fillcolor=lightblue];
  "end (6)" [style=filled fillcolor=lightblue];
  "assign sum = sum + i (7)" [style=filled fillcolor=lightblue];
  "assign i++ (8)" [style=filled fillcolor=lightblue];
  "return sum (9)" [style=filled fillcolor=lightblue];
  "Start" -> "decl i (1)";
  "decl i (1)" -> "decl sum = 0 (2)";
  "decl sum = 0 (2)" -> "assign i = 0 (3)";
  "assign i = 0 (3)" -> "for i < 5 (4)";
  "for i < 5 (4)" -> "loop (5)";
  "for i < 5 (4)" -> "end (6)";
  "loop (5)" -> "assign sum = sum + i (7)";
  "end (6)" -> "return sum (9)";
  "assign sum = sum + i (7)" -> "assign i++ (8)";
  "assign i++ (8)" -> "for i < 5 (4)";
}
